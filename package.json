{
  "name": "continuous-sample-typescript",
  "version": "0.1.0",
  "description": "A billing-support agent that ships on Continuous — CI/CD for AI agents.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "worker": "NODE_OPTIONS=--preserve-symlinks tsx src/worker.ts",
    "simulate": "tsx src/simulate.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.158",
    "yaml": "^2.5.0",
    "@continuous/sdk": "file:../continuous/sdk/typescript"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
