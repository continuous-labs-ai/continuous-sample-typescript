# Copy to .env and fill in. The worker reads these from the environment.
#   cp .env.example .env   &&   set -a && . ./.env && set +a

# --- Continuous (the platform) ---
# Worker API key — minted in the dashboard (Admin → Worker API keys).
CONTINUOUS_API_KEY=ck_...
# API base URL. Omit to use the default (https://api.continuouslabs.ai);
# point at your dev stack when testing locally.
CONTINUOUS_API_URL=https://api.continuouslabs.ai

# --- Anthropic (the agent runtime) ---
# The Claude Agent SDK spawns the bundled Claude Code engine, which calls
# Anthropic. Required for the worker to actually run a variant on a claimed task.
ANTHROPIC_API_KEY=sk-ant-...
